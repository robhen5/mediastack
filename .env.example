# Copy this file to .env on the target host and fill in real values.
# Keep .env private. Do not put real secrets in this example file.

# Host/user values to verify before deployment on Ubuntu Server or Unraid.
# Windows is useful for staging/testing only; do not run the production
# automation stack against the 28TB media drive from Docker Desktop.
TZ=America/New_York
PUID=1000
PGID=1000
RENDER_GID=107
VIDEO_GID=44
DOCKER_GID=999
MEDIASTACK_ROOT=/opt/mediastack
CONFIG_ROOT=/opt/mediastack/config
BACKUP_ROOT=/opt/mediastack/backups
DATA_ROOT=/media/storage/data
LAN_IP=192.168.1.10
LAN_SUBNET=192.168.1.0/24
TAILSCALE_IP=100.115.252.112
TAILSCALE_SUBNET=100.64.0.0/10
FIREWALL_PORTS="22 80 3000 3001 5055 6767 7878 8081 8096 8989 9696 2586 11011"

# Intended physical layout:
# - 512GB Lenovo SSD: OS, MEDIASTACK_ROOT, CONFIG_ROOT, BACKUP_ROOT
# - 28TB Exos HDD: DATA_ROOT, including both torrents and media for hardlinks
# - TerraMaster D9-320 later: expand DATA_ROOT through Unraid or a Linux pool

# Gluetun / ProtonVPN WireGuard.
WIREGUARD_PRIVATE_KEY=replace_with_proton_wireguard_private_key
WIREGUARD_ADDRESSES=replace_with_proton_wireguard_address

# qBittorrent WebUI credentials used by port-sync scripts and integrations.
QBIT_USER=replace_with_qbittorrent_username
QBIT_PASS=replace_with_qbittorrent_password

# App API keys. Create these in each app after first login/configuration.
SONARR_APIKEY=replace_after_sonarr_setup
RADARR_APIKEY=replace_after_radarr_setup
PROWLARR_APIKEY=replace_after_prowlarr_setup
BAZARR_APIKEY=replace_after_bazarr_setup
JELLYFIN_APIKEY=replace_after_jellyfin_setup

# Jellystat database/auth secrets.
JELLYSTAT_DB_PASSWORD=replace_with_long_random_password
JELLYSTAT_JWT_SECRET=replace_with_long_random_secret

# ntfy topic for local notifications. Treat as a low-value shared secret.
NTFY_TOPIC=mediastack-alerts

# Host disk health monitoring. Prefer stable /dev/disk/by-id paths, not
# /dev/sdX names. Add future TerraMaster DAS disks here after confirming
# smartctl can read them through the USB bridge.
SMART_DEVICES="/dev/disk/by-id/ata-ST28000NM001C_replace_with_real_serial"
SMARTCTL_OPTIONS=
SMART_TEMP_WARN_C=50
SMART_NTFY_URL=http://localhost:2586
SMART_NTFY_TOPIC=mediastack-alerts

# --- SAFETY DEFAULTS — review docs/SAFETY.md before changing any of these ---
# qbit_manage starts in REPORT-ONLY mode. Leave as `true` for at least the
# first 30 days. Only flip to `false` after reviewing a week of dry-run logs
# and confirming nothing legitimate is on the remove list.
QBT_DRY_RUN=true

# Unpackerr keeps extracted files indefinitely by default (9999h) so you can
# manually verify imports. After the first 30 days, set to something sane like
# `1h` once you trust the import flow.
UNPACKERR_DELETE_DELAY=9999h
