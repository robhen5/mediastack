[Unit]
Description=Mediastack: sync qBittorrent listen port with gluetun's NAT-PMP forwarded port
Documentation=file:///opt/mediastack/README.md
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
User=mediastack
Group=mediastack
ExecStart=/opt/mediastack/scripts/sync-qbit-port.sh
# Don't let a single failed run block the timer; the next tick will retry.
SuccessExitStatus=0
